# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key


# or SUPABASE_ANON_KEY for anon usage in local dev (less privileged)
# SUPABASE_ANON_KEY=your-anon-key

# PostgreSQL connection string used only by Knex migrations.
# Use the Supabase Database password, not SUPABASE_SERVICE_KEY.
# If the password has symbols such as #, @, %, /, ?, encode it for URL usage.
# Direct connection example:
DATABASE_URL=postgresql://postgres:your-url-encoded-db-password@db.your-project.supabase.co:5432/postgres?sslmode=require
# If direct connection is unavailable, use the Session Pooler URI from Supabase:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-url-encoded-db-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_SSL=true
# Auth
JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-chars

# Development fallback only for users that are not linked to a barbearia/barbeiro.
# Authenticated agenda routes use the logged user context, not these defaults.
# Use ids that already exist in Supabase public.barbearias/public.barbeiros.
DEFAULT_BARBEARIA_ID=00000000-0000-0000-0000-000000000000
# DEFAULT_BARBEIRO_ID=00000000-0000-0000-0000-000000000000

# Server port
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=true

# Frontend URL used to build email verification links.
APP_URL=http://localhost:5173

# SMTP is optional in local dev. If missing, verification links are printed in logs.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="Kash Flow <no-reply@example.com>"
