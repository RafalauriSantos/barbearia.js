# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key


# or SUPABASE_ANON_KEY for anon usage in local dev (less privileged)
# SUPABASE_ANON_KEY=your-anon-key

# PostgreSQL connection string from Supabase
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
# Auth
JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-chars

# Temporary defaults while auth/multi-tenant context is not wired yet.
# Use ids that already exist in Supabase public.barbearias/public.barbeiros.
DEFAULT_BARBEARIA_ID=00000000-0000-0000-0000-000000000000
# DEFAULT_BARBEIRO_ID=00000000-0000-0000-0000-000000000000

# Server port
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=true
