SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-url-encoded-db-password@db.your-project.supabase.co:5432/postgres?sslmode=require
DATABASE_SSL=true
JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-chars
DEFAULT_BARBEARIA_ID=00000000-0000-0000-0000-000000000000
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=true
# Em producao, use a URL publica do frontend. Se ficar vazio/localhost em NODE_ENV=production,
# o backend usa https://kurt-barbearia.vercel.app para evitar convites quebrados.
APP_URL=http://localhost:5173
AVATAR_BUCKET=barber-avatars

# Email
# Local/desenvolvimento pode usar SMTP; producao no Render Free deve usar Brevo API.
EMAIL_FROM=Gestor Barbearia <no-reply@seudominio.com>
EMAIL_BRAND_NAME=Gestor Barbearia
EMAIL_PROVIDER=brevo
EMAIL_TIMEOUT_MS=10000
BREVO_API_KEY=xkeysib-sua-chave-brevo
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
